# toolkit env template
#
# Copy to `.env`. Nothing here is secret by default; LLM_API_KEY is the only
# sensitive value and only needed if you use the `extract_structured` tool.

# --- Bun API ---
API_HOST=0.0.0.0
API_PORT=3000
LOG_LEVEL=info

# --- Python sidecar location (from api's POV) ---
# In docker-compose this is the service name; locally it's 127.0.0.1:8000.
PY_URL=http://py:8000

# --- OpenAI-compatible LLM backend for extract_structured ---
# Works with OpenAI, local llama.cpp (/v1), Ollama, etc. Leave blank if you
# don't need the extract_structured tool.
LLM_BASE_URL=
LLM_API_KEY=
LLM_DEFAULT_MODEL=

# --- SearXNG (web_search tool) ---
# The Bun api reads SEARXNG_URL to reach the metasearch instance. Default
# targets the bundled `searxng` compose service. Override to point at your
# own SearXNG instance (any reachable URL) and skip `--profile search`.
SEARXNG_URL=http://searxng:8080

# Required ONLY when running `docker compose --profile search up`. Signs
# SearXNG's own session cookies / CSRF tokens. Generate a fresh value with:
#   openssl rand -hex 32
SEARXNG_SECRET=

# Optional host bind for the bundled searxng service's web UI + /stats page.
# Defaults to loopback (127.0.0.1:8080) so the debug UI is reachable from
# the docker host without leaking to the LAN. Set to 100.x.x.x:8080 for
# tailnet access, or 0.0.0.0:8080 for LAN access.
SEARXNG_BIND=127.0.0.1:8080

# --- FlareSolverr (convert_url fetcher="stealth") ---
# The py sidecar routes HTML fetches through this URL when a convert_url
# call sets fetcher="stealth". Bypasses Cloudflare / WAF challenges by
# driving a headful Chromium. Default targets the bundled `flaresolverr`
# compose service (gated behind `--profile stealth`).
FLARESOLVERR_URL=http://flaresolverr:8191

# Optional host bind for the bundled flaresolverr service's API. Default
# loopback so you can hit /v1 with curl from the docker host without
# leaking. Set to 100.x.x.x:8191 for tailnet access.
FLARESOLVERR_BIND=127.0.0.1:8191

# Optional: FlareSolverr log level (debug/info/warning/error).
FLARESOLVERR_LOG_LEVEL=info

# Optional: paid captcha solver integration ("none", "hcaptcha-solver",
# etc.). Toolkit stays key-free by default. Enable only if you BYO a key.
FLARESOLVERR_CAPTCHA_SOLVER=none

# --- Reranker (BAAI/bge-reranker-v2-m3 or similar cross-encoder) ---
# When set, web_search re-orders SearXNG hits via this backend, and the
# standalone `rerank` tool becomes usable. Point at any service that
# speaks the Cohere-compatible /rerank shape:
#   - Infinity (docker run michaelf34/infinity v2 --model-id ...)
#   - HuggingFace TEI with a cross-encoder model
#   - Cohere's hosted rerank-v3 (https://api.cohere.com/v1)
#   - A self-hosted FastAPI wrapper around FlagEmbedding's FlagReranker
#
# Recommended model: BAAI/bge-reranker-v2-m3 (568M, multilingual, fp16 ~1.5 GB
# VRAM, 512-token cap). See https://huggingface.co/BAAI/bge-reranker-v2-m3.
# Higher-quality alternatives: bge-reranker-v2-gemma (9B, 8K seq) or
# bge-reranker-v2-minicpm-layerwise (2.7B).
#
# Note: Ollama does not serve cross-encoder rerankers natively (as of early
# 2026). If your local LLM story is Ollama-based, stand up Infinity or TEI
# alongside it for the reranker specifically.
#
# Leave blank to disable reranking across both tools.
RERANKER_URL=
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
